#!/bin/sh


if [ -d /etc/X11/xinit/xinitrc.d ]; then
	for f in /etc/X11/xinit/xinitrc.d/*; do
		if [ -x "$f" ]; then
			. "$f"
		fi
	done
	unset f
fi

if [ -f ~/.Xprofile ]; then
	. ~/.Xprofile
fi

xhost local:root

xrandr --dpi 192

xrdb -merge ~/.Xresources

#export QT_AUTO_SCREEN_SCALE_FACTOR=1
#export GDK_SCALE=2
#export GDK_DPI_SCALE=0.5

exec i3 -V >> ~/.i3/logfile 2>&1
