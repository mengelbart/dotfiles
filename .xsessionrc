#!/bin/sh


if [ -d /etc/X11/xinit/xinitrc.d ]; then
	for f in /etc/X11/xinit/xinitrc.d/*; do
		if [ -x "$f" ]; then
			. "$f"
		fi
	done
	unset f
fi

if [ -f ~/.Xprofile ]; then
	. ~/.Xprofile
fi

xhost local:root

xrandr --output DVI-I-1 --right-of HDMI-1
xrandr --dpi 96

exec i3 -V >> ~/.i3/logfile 2>&1
